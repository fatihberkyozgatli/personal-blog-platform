# Supabase — copy to .env.local and fill in from your Supabase project settings.
# Until these are set, the app renders with built-in sample content (no auth/DB).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL (used for sitemap, RSS, OG metadata). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
